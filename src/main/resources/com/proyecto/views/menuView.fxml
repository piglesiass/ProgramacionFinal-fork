<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import java.lang.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.proyecto.controllers.MenuController">
   <children>
      <Label text="Combate pokemon" styleClass="title"/>
      <Label text="Elige tu pokemon:" />
      <ComboBox fx:id="creatureComboBox" prefWidth="200" />
      <Label fx:id="infoLabel" text="" wrapText="true" prefWidth="250"/>
      <Button fx:id="startBtn" text="Combatir!" />
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>